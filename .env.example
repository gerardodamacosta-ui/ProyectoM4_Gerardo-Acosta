# .env.example — plantilla SIN valores reales. Este archivo SÍ se sube al repo.
# Copialo a .env y completá los valores. El .env NUNCA se sube (está en .gitignore).

# Firebase (frontend — prefijo VITE_ obligatorio para que Vite lo exponga al cliente)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AWS SES (solo serverless — SIN prefijo VITE_ para que no llegue al navegador)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SES_FROM_EMAIL=

